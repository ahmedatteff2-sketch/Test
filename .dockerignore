# Keep the Docker build context small and reproducible: dependencies and build
# artifacts are regenerated inside the image, not copied from the host.

# Dependencies
**/node_modules

# Front-end build outputs (regenerated by the web build stage)
apps/web/.next
apps/web/out

# Embedded export (regenerated via COPY --from=web in the Dockerfile)
apps/api/internal/web/dist

# Local Go binaries
apps/api/main
apps/api/server

# VCS, tooling, OS cruft
.git
.gitignore
.idea
.vscode
.DS_Store
**/*.log
